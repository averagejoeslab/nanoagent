FROM node:20-slim

# Install essential tools for agent execution
RUN apt-get update && apt-get install -y \
    bash \
    curl \
    git \
    python3 \
    python3-pip \
    && rm -rf /var/lib/apt/lists/*

# Create workspace
WORKDIR /workspace

# Keep container running for persistent sessions
# Note: Container will run as host user via --user flag for proper file permissions
CMD ["sleep", "infinity"]
